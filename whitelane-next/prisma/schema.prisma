// Default: SQLite (local dev, same file as Laravel at ../../database/database.sqlite).
// For managed Postgres (e.g. Vercel/Neon), switch `provider` to `postgresql` and set DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int       @id @default(autoincrement())
  name                String
  email               String    @unique
  emailVerifiedAt     DateTime? @map("email_verified_at")
  password            String
  rememberToken       String?   @map("remember_token")
  phone               String?   @unique
  username            String?   @unique
  role                String    @default("driver")
  mustResetPassword   Boolean   @default(false) @map("must_reset_password")
  isOnline            Boolean   @default(false) @map("is_online")
  lastLat             Decimal?  @map("last_lat")
  lastLng             Decimal?  @map("last_lng")
  accountStatus       String    @default("active") @map("account_status")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  trips         Trip[]         @relation("DriverTrips")

  @@map("users")
}

model PersonalAccessToken {
  id            Int       @id @default(autoincrement())
  tokenableType String    @map("tokenable_type")
  tokenableId   Int       @map("tokenable_id")
  name          String
  token         String    @unique
  abilities     String?
  lastUsedAt    DateTime? @map("last_used_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([tokenableType, tokenableId])
  @@map("personal_access_tokens")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("refresh_tokens")
}

model Trip {
  id                  Int      @id @default(autoincrement())
  pickupAddress       String   @map("pickup_address")
  dropoffAddress      String   @map("dropoff_address")
  scheduledAt         DateTime @map("scheduled_at")
  customerDisplayName String   @map("customer_display_name")
  vehicleTypeLabel    String   @default("Standard") @map("vehicle_type_label")
  segment             String   @default("b2c")
  driverStatus        String   @default("offered") @map("driver_status")
  paymentPaid         Boolean  @default(false) @map("payment_paid")
  driverId            Int?     @map("driver_id")
  driver              User?    @relation("DriverTrips", fields: [driverId], references: [id], onDelete: SetNull)
  pickupLat           Decimal? @map("pickup_lat")
  pickupLng           Decimal? @map("pickup_lng")
  dropoffLat          Decimal? @map("dropoff_lat")
  dropoffLng          Decimal? @map("dropoff_lng")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("trips")
}
