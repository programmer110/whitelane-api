# Required — Supabase Data API (used by Next.js server routes via @supabase/supabase-js)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Use either the new publishable name or the dashboard’s anon key:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Strongly recommended on Vercel: server-only key (never NEXT_PUBLIC_*). Bypasses RLS; keep secret.
# SUPABASE_SERVICE_ROLE_KEY=

WHITELANE_OTP_FALLBACK_TO_PASSWORD=true

# Optional — matches Laravel sanctum.token_prefix
# SANCTUM_TOKEN_PREFIX=
