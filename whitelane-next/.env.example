# SQLite — shared with Laravel at ../database/database.sqlite (create with: touch ../database/database.sqlite && cd .. && php artisan migrate)
DATABASE_URL="file:../../database/database.sqlite"

WHITELANE_OTP_FALLBACK_TO_PASSWORD=true

# Optional — matches Laravel sanctum.token_prefix
# SANCTUM_TOKEN_PREFIX=

# Production (Postgres): set provider in prisma/schema.prisma to postgresql and use e.g.
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
