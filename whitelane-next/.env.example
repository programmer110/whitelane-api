# Supabase Postgres — Dashboard → Project Settings → Database → Connection string
# Prefer "Transaction" pooler (port 6543) for serverless; add pgbouncer=true for Prisma:
# DATABASE_URL="postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Or use the direct connection (port 5432) for long-lived processes / migrations:
# DATABASE_URL="postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].supabase.co:5432/postgres?sslmode=require"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

WHITELANE_OTP_FALLBACK_TO_PASSWORD=true

# Optional — matches Laravel sanctum.token_prefix
# SANCTUM_TOKEN_PREFIX=

# Supabase JS client (@supabase/supabase-js / @supabase/ssr) — Auth, Storage, Realtime
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
